{
  "name": "haber",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"pnpm --filter @haber/backend dev\" \"pnpm --filter @haber/frontend dev\"",
    "build": "pnpm --filter @haber/shared build && pnpm --filter @haber/backend build && pnpm --filter @haber/frontend build",
    "build:shared": "pnpm --filter @haber/shared build",
    "build:backend": "pnpm --filter @haber/backend build",
    "build:frontend": "pnpm --filter @haber/frontend build",
    "test": "pnpm --filter @haber/backend test",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "prepare": "husky",
    "docker:dev": "docker compose up --build",
    "docker:prod": "docker compose -f docker-compose.yml -f docker-compose.prod.yml up --build"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "concurrently": "^9.0.0",
    "husky": "^9.1.0",
    "lint-staged": "^15.2.8",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "@swc/core",
      "bcrypt",
      "esbuild",
      "prisma"
    ]
  }
}
