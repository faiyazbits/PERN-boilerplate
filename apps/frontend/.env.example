# All frontend env vars MUST start with VITE_ — they are baked into the JS bundle at build time
# Never put secrets here

VITE_APP_TITLE=Haber
# VITE_API_URL=http://localhost:3000
# Leave VITE_API_URL unset in development — Vite proxy handles /api/* → localhost:3000
# In production Docker, nginx handles the /api proxy — no VITE_API_URL needed
